# Blokir akses langsung ke file konfigurasi & skema database
<FilesMatch "^(config\.php|schema\.sql)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Nonaktifkan directory listing
Options -Indexes
